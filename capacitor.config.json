{
  "appId": "com.nicklews.pomo",
  "appName": "Pomo",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#1a1a2e",
    "statusBarStyle": "Dark",
    "allowsLinkPreview": false,
    "scrollEnabled": false,
    "limitsNavigationsToAppBoundDomains": true
  },
  "android": {
    "backgroundColor": "#1a1a2e",
    "allowMixedContent": false,
    "captureInput": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#1a1a2e",
      "showSpinner": false
    }
  }
}
